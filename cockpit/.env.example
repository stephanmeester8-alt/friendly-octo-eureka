# Cockpit environment (copy to cockpit/.env.local)
WORKSPACE_ROOT=../workspace
AGENT_GATEWAY_URL=http://127.0.0.1:18789
AGENT_GATEWAY_TIMEOUT_MS=30000
# Optional when gateway.auth.mode is "token"
AGENT_GATEWAY_TOKEN=
# OpenClaw gateway client handshake (must be a protocol-allowed id, e.g. gateway-client)
AGENT_GATEWAY_CLIENT_ID=gateway-client
AGENT_GATEWAY_CLIENT_MODE=backend
# Protocol negotiation (OpenClaw 2026.4+ uses v5; defaults negotiate v4..v5)
# AGENT_GATEWAY_PROTOCOL_VERSION=5
# AGENT_GATEWAY_MIN_PROTOCOL_VERSION=4
# AGENT_GATEWAY_MAX_PROTOCOL_VERSION=5
