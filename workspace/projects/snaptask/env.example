# Supabase — Phase 1
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[JOUW_PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[JOUW_ANON_KEY]
# Service role — server only (Stripe webhook). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=[JOUW_SERVICE_ROLE_KEY]

# Set to false once real Supabase keys are filled in
NEXT_PUBLIC_DEMO_MODE=true

# Optional public app URL (Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — Phase 2 (platform credits / emulated wallet)
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
